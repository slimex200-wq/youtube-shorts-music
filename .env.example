# LLM (Claude CLI uses Max subscription — no key needed)
# Set this only if using API mode (LLM_MODE=api)
ANTHROPIC_API_KEY=

# YouTube Data API v3 (for channel sync + stats)
YOUTUBE_API_KEY=

# Your YouTube channel handle (e.g. @YourChannel)
YOUTUBE_CHANNEL_HANDLE=

# Artist name for title cards (leave empty to skip)
ARTIST_NAME=

# LLM backend: "claude_cli" (default, free on Max) or "api"
# LLM_MODE=claude_cli
